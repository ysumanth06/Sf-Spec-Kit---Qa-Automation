# ── QA Tester Identity ─────────────────────────────────────
# Unique prefix for test records (use your name, all caps)
QA_PREFIX=SARAH

# ── Salesforce QA Org - sf CLI Connection (Primary) ──────────
# If you have sf CLI configured with an org alias, set it here.
# This is the fastest auth method and avoids JWT setup entirely.
E2E_ADMIN_ALIAS=my-qa-sandbox

# ── Salesforce QA Org - JWT Authentication (Fallback) ────────
# Used when sf CLI alias is not available or for per-profile auth.
E2E_AUTH_MODE=jwt
E2E_JWT_CLIENT_ID=3MVG9...your_connected_app_consumer_key
E2E_JWT_KEY_FILE=certs/server.key
E2E_JWT_INSTANCE_URL=https://company--qa.sandbox.my.salesforce.com

# ── Test Users (personas) ─────────────────────────────────────
# Preferred: copy personas.example.json -> personas.json and edit usernames/aliases.
# Fallback: E2E_JWT_USERS when personas.json is missing.
#
# Legacy format (Playwright project name = first column):
#   "Label:sfCliAlias:salesforceUsername"
# Extended (same as sf-e2e-testing runner): add role and permission sets:
#   "Label:alias:username:role:PS1;PS2"
#
# - Label: Playwright project / persona name (or profile name if no personas.json)
# - sfCliAlias: sf CLI org alias for this user
# - salesforceUsername: JWT sub claim
E2E_JWT_USERS=System Administrator:qa-admin:qa.admin@company.com.qa,Standard User:qa-standard:qa.standard@company.com.qa,Read Only:qa-readonly:qa.readonly@company.com.qa

# ── Optional Settings ─────────────────────────────────────
# Headed mode (true = watch the browser, false = headless)
HEADED=true

# Number of parallel browser workers
WORKERS=1

# Session / UX tuning (optional)
# E2E_SESSION_TIMEOUT_MINUTES=120
# E2E_ACTION_TIMEOUT_MS=20000
# E2E_VISUAL_MAX_DIFF_PIXELS=200

# Default objects to generate tests for (comma-separated)
DEFAULT_OBJECTS=Account,Contact

# Jira project prefix for report filenames
JIRA_PREFIX=CSSFHC

# Optional: set to "false" to disable Excel output from the RCA reporter on failures
# QA_EXCEL_REPORT=true

# Experience Cloud base URL for community smoke tests and doctor HEAD check (optional)
# COMMUNITY_URL=https://mydomain--sandbox.my.site.com/partner

# Optional: bind RCA Excel / reports to a Jira story id
# JIRA_ID=CSSFHC-1234
